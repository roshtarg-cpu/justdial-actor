{
  "title": "JustDial Scraper Input",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "searchQuery": {
      "title": "Search Query",
      "type": "string",
      "description": "Business type to search, e.g. 'restaurants', 'dentists', 'plumbers'.",
      "editor": "textfield",
      "example": "restaurants"
    },
    "city": {
      "title": "City",
      "type": "string",
      "description": "Indian city name, e.g. 'Delhi', 'Mumbai', 'Bangalore'.",
      "editor": "textfield",
      "example": "Delhi"
    },
    "maxResults": {
      "title": "Max Results",
      "type": "integer",
      "description": "Maximum number of listings to return. One JustDial page returns ~10–20 listings.",
      "default": 50,
      "minimum": 1,
      "maximum": 500,
      "editor": "number"
    },
    "proxyConfiguration": {
      "title": "Proxy Configuration",
      "type": "object",
      "description": "Apify proxy settings. Residential proxies are strongly recommended to avoid blocks.",
      "editor": "proxy",
      "prefill": {
        "useApifyProxy": true,
        "apifyProxyGroups": ["RESIDENTIAL"]
      }
    }
  },
  "required": ["searchQuery", "city"]
}
