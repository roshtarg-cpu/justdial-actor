{
  "title": "JustDial Scraper Input",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "searchQuery": {
      "title": "Search Query",
      "type": "string",
      "description": "Business type to search, e.g. 'restaurants', 'dentists', 'plumbers'.",
      "editor": "textfield",
      "default": "restaurants"
    },
    "city": {
      "title": "City",
      "type": "string",
      "description": "Indian city name, e.g. 'Delhi', 'Mumbai', 'Bangalore'.",
      "editor": "textfield",
      "default": "Delhi"
    },
    "maxResults": {
      "title": "Max Results",
      "type": "integer",
      "description": "Maximum number of listings to return. One JustDial page returns ~10 listings.",
      "default": 50,
      "minimum": 1,
      "maximum": 500,
      "editor": "number"
    },
    "scraperApiKey": {
      "title": "ScraperAPI Key",
      "type": "string",
      "description": "Your ScraperAPI key. Optional — a default key is built in.",
      "editor": "textfield"
    }
  },
  "required": ["searchQuery", "city"]
}
